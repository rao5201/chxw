<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <directoryBrowse enabled="false"/>
    <security>
      <requestFiltering>
        <fileExtensions>
          <add fileExtension=".sql" allowed="false"/>
          <add fileExtension=".log" allowed="false"/>
          <add fileExtension=".cnf" allowed="false"/>
        </fileExtensions>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
